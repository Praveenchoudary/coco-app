# Copy this file to .env and fill in your values

# Razorpay (get from dashboard.razorpay.com > Settings > API Keys)
# Use rzp_test_xxx for testing, rzp_live_xxx for production
REACT_APP_RZP_KEY_ID=rzp_test_CHANGE_ME

# Stripe (optional - for international card payments)
REACT_APP_STRIPE_PK=pk_test_CHANGE_ME
